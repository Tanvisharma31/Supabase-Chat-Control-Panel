SUPABASE_ACCESS_TOKEN=
SUPABASE_ORGANIZATION_ID=
SUPABASE_PROJECT_REGION=
SUPABASE_MCP_COMMAND="npx tsx ./packages/mcp-core/src/customMcpServer.ts"

# Production web (Vercel): public URL of the Express API, no trailing slash.
# VITE_API_BASE_URL=https://your-api.onrender.com

# API (Vercel/Node): comma-separated allowed browser origins. Optional if your
# frontend is on *.vercel.app or the default production URL above.
# CORS_ORIGIN=https://your-web.vercel.app